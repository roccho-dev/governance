{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "repo-convention.intent.v1",
  "type": "object",
  "required": [
    "kind",
    "repo",
    "repo_class",
    "severity",
    "readme_mode",
    "governance_mode",
    "governance_ref",
    "ci_intent_path",
    "readme_path"
  ],
  "properties": {
    "kind": { "const": "repo-convention.intent.v1" },
    "repo": { "type": "string", "minLength": 1 },
    "repo_class": { "enum": ["normal", "root_authority", "bootstrap"] },
    "severity": { "enum": ["report_only", "warning", "blocking"] },
    "readme_mode": { "enum": ["checked_handwritten", "managed_block", "generated"] },
    "governance_mode": { "enum": ["flake_lib", "flake_false_path", "shadow_unconnected"] },
    "governance_ref": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["commit", "digest", "branch", "path", "missing"] },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ci_intent_path": { "type": "string", "minLength": 1 },
    "readme_path": { "type": "string", "minLength": 1 },
    "exceptions": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
